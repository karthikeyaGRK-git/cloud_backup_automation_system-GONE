        storageUsedGB:     (azureStats.totalSize / 1024**3).toFixed(2),
        storageLimitGB:    (req.user.azure?.storageLimitBytes / 1024**3).toFixed(0),
        blobCount:         azureStats.blobCount,
        simulated:         azureStats.simulated,
        storageUsedPct:    req.user.storageUsedPct,
