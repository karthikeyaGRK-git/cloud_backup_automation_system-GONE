let JWT_SECRET = process.env.JWT_SECRET || "dev_secret_change_me_min_32_chars!";

const signToken = id => jwt.sign({ id }, JWT_SECRET, { expiresIn: process.env.JWT_EXPIRES_IN || "7d" });

class AppError extends Error {
  constructor(msg, code) {
    super(msg); this.statusCode = code;
    this.status = String(code).startsWith("4") ? "fail" : "error";
    this.isOperational = true;
    Error.captureStackTrace(this, this.constructor);
  }
}

const wrap   = fn => (req, res, next) => Promise.resolve(fn(req, res, next)).catch(next);
const vcheck = (req, res, next) => {
  const err = validationResult(req);
  if (!err.isEmpty()) return res.status(400).json({ success: false, errors: err.array() });
  next();
};

// Track event in App Insights
const trackEvent = (name, properties = {}) => {
  if (appInsights?.defaultClient) {
    appInsights.defaultClient.trackEvent({ name, properties });
  }
};
const trackMetric = (name, value) => {
  if (appInsights?.defaultClient) {
    appInsights.defaultClient.trackMetric({ name, value });
  }
};

