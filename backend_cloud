      jobsByStatus:  jobsByStatus.reduce((a,i) => ({ ...a, [i._id]: i.count }), {}),
      last30Days:    { success, failed, total },
      dailyActivity,
      recentActivity: recentLogs,
      azure: {
        storageAccount:    AZURE_ACCOUNT     || "not configured",
        containerName:     AZURE_CONTAINER,
        connected:         !!backupContainerClient,
        keyVaultEnabled:   !!kvClient,
        insightsEnabled:   !!appInsights,
