app.get("/api/dashboard/stats", protect, wrap(async (req, res) => {
  const uid   = req.user._id;
  const last30 = new Date(Date.now() - 30*24*60*60*1000);
  const last7  = new Date(Date.now() -  7*24*60*60*1000);

  const [totalJobs, activeJobs, jobsByStatus, recentLogs, monthStats, dailyActivity, allTimeStorage] = await Promise.all([
    BackupJob.countDocuments({ user: uid }),
    BackupJob.countDocuments({ user: uid, status: "active" }),
    BackupJob.aggregate([{ $match: { user: uid } }, { $group: { _id: "$status", count: { $sum: 1 } } }]),
    BackupLog.find({ user: uid }).sort({ startTime: -1 }).limit(10).populate("job","name source destination"),
    BackupLog.aggregate([
      { $match: { user: uid, startTime: { $gte: last30 } } },
      { $group: { _id: "$status", count: { $sum: 1 }, data: { $sum: "$dataSize.transferred" } } },
    ]),
    BackupLog.aggregate([
      { $match: { user: uid, startTime: { $gte: last7 } } },
      { $group: {
        _id: { $dateToString: { format: "%Y-%m-%d", date: "$startTime" } },
        completed:       { $sum: { $cond: [{ $eq: ["$status","completed"] }, 1, 0] } },
        failed:          { $sum: { $cond: [{ $eq: ["$status","failed"]    }, 1, 0] } },
        dataTransferred: { $sum: "$dataSize.transferred" },
        blobsCreated:    { $sum: 1 },
      }},
      { $sort: { _id: 1 } },
    ]),
    BackupLog.aggregate([
      { $match: { user: uid, status: "completed" } },
      { $group: { _id: null, total: { $sum: "$dataSize.transferred" }, blobs: { $sum: 1 } } },
