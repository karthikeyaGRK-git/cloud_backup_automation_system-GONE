/**
 * Upload a backup to Azure Blob Storage.
 * blobName: e.g. "jobId/2024-01-15/backup-<uuid>.tar.gz"
 * buffer:   Buffer or string (simulated)
 */
const uploadBackupToAzure = async (blobName, buffer, metadata = {}) => {
  if (!backupContainerClient) {
    // Simulation for demo
    return { url: `https://${AZURE_ACCOUNT||"demo"}.blob.core.windows.net/${AZURE_CONTAINER}/${blobName}`, simulated: true };
  }
  const blockBlobClient = backupContainerClient.getBlockBlobClient(blobName);
  const uploadOptions = {
    blobHTTPHeaders: { blobContentType: "application/gzip" },
    metadata: {
      createdBy:   metadata.userId   || "system",
      jobId:       metadata.jobId    || "",
      jobName:     metadata.jobName  || "",
      runId:       metadata.runId    || "",
      environment: process.env.NODE_ENV || "development",
      ...metadata,
    },
    tags: {
      jobId:  metadata.jobId  || "",
      status: "active",
    },
  };
  await blockBlobClient.upload(buffer, Buffer.byteLength(buffer), uploadOptions);
  return { url: blockBlobClient.url, simulated: false };
};

/**
 * Generate a time-limited SAS URL for download
 */
const generateSasUrl = (blobName, expiryHours = 2) => {
  if (!AZURE_ACCT_KEY || !blobServiceClient) return null;
  const sharedKey  = new StorageSharedKeyCredential(AZURE_ACCOUNT, AZURE_ACCT_KEY);
  const expiresOn  = new Date(Date.now() + expiryHours * 60 * 60 * 1000);
  const sasToken   = generateBlobSASQueryParameters(
    {
      containerName: AZURE_CONTAINER,
      blobName,
      permissions:   BlobSASPermissions.parse("r"), // read-only
      expiresOn,
      contentDisposition: `attachment; filename="${blobName.split("/").pop()}"`,
    },
    sharedKey
  ).toString();
  return `https://${AZURE_ACCOUNT}.blob.core.windows.net/${AZURE_CONTAINER}/${blobName}?${sasToken}`;
};

/**
 * List blobs for a job (prefix = jobId/)
 */
const listJobBlobs = async (jobId, limit = 20) => {
  if (!backupContainerClient) return [];
  const results = [];
  for await (const blob of backupContainerClient.listBlobsFlat({ prefix: `${jobId}/` })) {
    results.push({
      name:         blob.name,
      size:         blob.properties.contentLength,
      createdOn:    blob.properties.createdOn,
      lastModified: blob.properties.lastModified,
      contentType:  blob.properties.contentType,
    });
    if (results.length >= limit) break;
  }
  return results;
};

/**
 * Delete old blobs beyond retention policy
 */
const applyRetentionPolicy = async (jobId, retentionDays, maxVersions) => {
  if (!backupContainerClient) return { deleted: 0 };
  const blobs = [];
  const cutoff = new Date(Date.now() - retentionDays * 24 * 60 * 60 * 1000);
  for await (const blob of backupContainerClient.listBlobsFlat({ prefix: `${jobId}/` })) {
    blobs.push(blob);
  }
  // Sort oldest first
  blobs.sort((a, b) => new Date(a.properties.createdOn) - new Date(b.properties.createdOn));
  const toDelete = blobs.filter(b =>
    new Date(b.properties.createdOn) < cutoff || blobs.indexOf(b) < blobs.length - maxVersions
  );
  let deleted = 0;
  for (const blob of toDelete) {
    await backupContainerClient.deleteBlob(blob.name);
    deleted++;
  }
  return { deleted };
};

/**
 * Get Azure Blob Storage usage stats for a user
 */
const getStorageStats = async (userId) => {
  if (!backupContainerClient) return { totalSize: 0, blobCount: 0, simulated: true };
  let totalSize = 0, blobCount = 0;
  for await (const blob of backupContainerClient.listBlobsFlat({ prefix: `${userId}/` })) {
    totalSize += blob.properties.contentLength || 0;
    blobCount++;
  }
  return { totalSize, blobCount, simulated: false };
};

