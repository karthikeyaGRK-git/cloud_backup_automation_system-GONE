    success: true, data: {
      overview: {
        totalJobs, activeJobs, totalRuns: total,
        successRate: total ? Math.round((success/total)*100) : 0,
        totalDataTransferred: totalGB,
        totalDataTransferredGB: (totalGB / 1024**3).toFixed(2),
