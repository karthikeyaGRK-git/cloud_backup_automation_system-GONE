//  6. AUTH MIDDLEWARE
// ═══════════════════════════════════════════════════════════════════════════
const protect = wrap(async (req, res, next) => {
  const auth = req.headers.authorization;
  if (!auth?.startsWith("Bearer ")) throw new AppError("No token provided.", 401);
  const decoded = jwt.verify(auth.split(" ")[1], JWT_SECRET);
  const user = await User.findById(decoded.id).select("+passwordChangedAt");
  if (!user)            throw new AppError("User not found.",            401);
  if (!user.isActive)   throw new AppError("Account deactivated.",       401);
  if (user.passwordChangedAfter(decoded.iat)) throw new AppError("Password changed. Re-login.", 401);
  req.user = user; next();
});

const restrictTo = (...roles) => (req, res, next) => {
  if (!roles.includes(req.user.role)) throw new AppError("Insufficient permissions.", 403);
  next();
};

