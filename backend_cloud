/* POST /api/auth/register */
app.post("/api/auth/register",
  [
    body("name").trim().isLength({ min:2, max:100 }).withMessage("Name must be 2–100 chars"),
    body("email").isEmail().normalizeEmail().withMessage("Valid email required"),
    body("password").isLength({ min:8 }).withMessage("Password min 8 chars")
      .matches(/(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/).withMessage("Needs uppercase, lowercase & number"),
  ], vcheck,
  wrap(async (req, res) => {
    const { name, email, password } = req.body;
    if (await User.findOne({ email })) throw new AppError("Email already registered.", 400);
    const user = await User.create({ name, email, password });
    trackEvent("UserRegistered", { userId: user._id.toString(), email });
    user.password = undefined;
    res.status(201).json({ success: true, token: signToken(user._id), data: { user } });
  })
);

/* POST /api/auth/login */
app.post("/api/auth/login",
  [body("email").isEmail().normalizeEmail(), body("password").notEmpty()], vcheck,
  wrap(async (req, res) => {
    const { email, password } = req.body;
