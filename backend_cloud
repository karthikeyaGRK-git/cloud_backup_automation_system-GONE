const connectDB = async (retries = 0) => {
  try {
    // Fetch MONGODB_URI from Key Vault if available
    const uri = await getSecret("mongodb-uri", "MONGODB_URI") || "mongodb://localhost:27017/cloud_backup_db";
    await mongoose.connect(uri, { maxPoolSize: 10, serverSelectionTimeoutMS: 5000 });
    console.log(`[DB] MongoDB connected → ${mongoose.connection.host} ✓`);
  } catch (err) {
    if (retries < 5) {
      console.warn(`[DB] Retry ${retries + 1}/5 — ${err.message}`);
      await new Promise(r => setTimeout(r, 3000));
      return connectDB(retries + 1);
    }
    console.error("[DB] Fatal: Could not connect. Exiting."); process.exit(1);
  }
};
mongoose.connection.on("disconnected", () => console.warn("[DB] Disconnected"));
mongoose.connection.on("reconnected",  () => console.log("[DB]  Reconnected ✓"));

