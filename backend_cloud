const AZURE_ACCT_KEY  = process.env.AZURE_STORAGE_ACCOUNT_KEY;
const AZURE_CONTAINER = process.env.AZURE_STORAGE_CONTAINER || "backups";

const initBlobStorage = async () => {
  if (!AZURE_ACCOUNT) {
    console.warn("[Azure Blob] AZURE_STORAGE_ACCOUNT_NAME not set — using simulated storage");
    return false;
  }
  try {
    if (AZURE_ACCT_KEY) {
      // Authenticate with account key (simple, good for dev/staging)
      const sharedKey = new StorageSharedKeyCredential(AZURE_ACCOUNT, AZURE_ACCT_KEY);
      blobServiceClient = new BlobServiceClient(
        `https://${AZURE_ACCOUNT}.blob.core.windows.net`, sharedKey
      );
    } else {
      // Authenticate with DefaultAzureCredential (Managed Identity in production)
      blobServiceClient = new BlobServiceClient(
        `https://${AZURE_ACCOUNT}.blob.core.windows.net`,
        new DefaultAzureCredential()
      );
    }
    backupContainerClient = blobServiceClient.getContainerClient(AZURE_CONTAINER);
    // Auto-create container if it doesn't exist
    await backupContainerClient.createIfNotExists({ access: "private" });
    console.log(`[Azure Blob] Connected → ${AZURE_ACCOUNT}/${AZURE_CONTAINER} ✓`);
    return true;
  } catch (err) {
    console.error(`[Azure Blob] Init failed: ${err.message}`);
    return false;
  }
};

/* ── 1b. Azure Key Vault client ────────────────────────────────────────── */
let kvClient = null;

const initKeyVault = async () => {
  const vaultUri = process.env.AZURE_KEYVAULT_URI;
  if (!vaultUri) { console.warn("[Azure KV] Skipped — AZURE_KEYVAULT_URI not set"); return; }
  try {
    let credential;
    if (process.env.AZURE_CLIENT_ID && process.env.AZURE_CLIENT_SECRET && process.env.AZURE_TENANT_ID) {
      credential = new ClientSecretCredential(
        process.env.AZURE_TENANT_ID,
        process.env.AZURE_CLIENT_ID,
        process.env.AZURE_CLIENT_SECRET
      );
    } else {
      credential = new DefaultAzureCredential(); // works on Azure VMs/App Service with MSI
    }
    kvClient = new SecretClient(vaultUri, credential);
    // Verify connectivity by listing one secret
    for await (const _ of kvClient.listPropertiesOfSecrets()) { break; }
    console.log(`[Azure KV] Connected → ${vaultUri} ✓`);
  } catch (err) {
    console.warn(`[Azure KV] Init failed: ${err.message} — falling back to env vars`);
  }
};

// Fetch a secret: Key Vault first, then env var fallback
const getSecret = async (kvName, envName) => {
  if (kvClient) {
    try { return (await kvClient.getSecret(kvName)).value; } catch {}
  }
  return process.env[envName];
};

