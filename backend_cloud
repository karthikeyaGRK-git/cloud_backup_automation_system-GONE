// ═══════════════════════════════════════════════════════════════════════════
// 12. AZURE BACKUP EXECUTION ENGINE
// ═══════════════════════════════════════════════════════════════════════════
async function executeAzureBackup(job, log, user) {
  const delay = ms => new Promise(r => setTimeout(r, ms));

  try {
    const startMs  = Date.now();
    const success  = Math.random() > 0.12;  // 88% success rate
    const fileCount = 10 + Math.floor(Math.random() * 990);
    const origSize  = Math.floor(Math.random() * 500 * 1024 * 1024); // up to 500 MB
    const compSize  = Math.floor(origSize * (job.compression.enabled ? 0.62 : 1.0));

    // Simulate backup processing time
    await delay(2500 + Math.floor(Math.random() * 6000));

    if (success) {
      // ── Build Azure blob name ─────────────────────────────────────────
      const date     = new Date().toISOString().split("T")[0];
      const blobName = `${user._id}/${job._id}/${date}/backup-${log.runId.split("-")[0]}.tar${job.compression.enabled ? ".gz" : ""}`;

      // ── Upload to Azure Blob Storage ──────────────────────────────────
      const uploadStart = Date.now();
      const fakeBuffer  = Buffer.alloc(Math.min(compSize, 1024), "x"); // real impl: actual compressed archive
      const uploadResult = await uploadBackupToAzure(blobName, fakeBuffer, {
        userId:  user._id.toString(),
        jobId:   job._id.toString(),
        jobName: job.name,
        runId:   log.runId,
        tier:    job.destination.azureTier || "Cool",
      });
      const uploadDurationMs = Date.now() - uploadStart;

      // ── Generate SAS download URL ─────────────────────────────────────
      const expiryHrs = +(process.env.AZURE_STORAGE_SAS_EXPIRY_HRS || 2);
      const sasUrl    = generateSasUrl(blobName, expiryHrs);
      const sasExpiry = new Date(Date.now() + expiryHrs * 60 * 60 * 1000);

      // ── Checksum ──────────────────────────────────────────────────────
      const checksum = crypto.randomBytes(16).toString("hex");

      // ── Update BackupLog ──────────────────────────────────────────────
      const duration = Date.now() - startMs;
      await BackupLog.findByIdAndUpdate(log._id, {
        status: "completed", endTime: new Date(), duration,
        dataSize:       { original: origSize, compressed: compSize, transferred: compSize },
        filesProcessed: { total: fileCount, success: fileCount, failed: 0, skipped: Math.floor(Math.random() * 5) },
        outputPath:     uploadResult.url,
        checksum,
        azure: {
          blobName, blobUrl: uploadResult.url, blobSasUrl: sasUrl, sasExpiresAt: sasExpiry,
          storageAccount: AZURE_ACCOUNT || "simulated",
          containerName:  AZURE_CONTAINER,
          tier:           job.destination.azureTier || "Cool",
          uploadDurationMs,
          compressionRatio: origSize > 0 ? +(origSize / compSize).toFixed(2) : 1,
          encryptionUsed:   job.encryption.enabled,
          keyVaultSecretName: job.encryption.keyVaultSecretName || null,
          simulated:      uploadResult.simulated,
        },
        $push: { logs: { level: "info", message: `Uploaded to Azure Blob: ${blobName} (${uploadResult.simulated ? "simulated" : "real"})` } },
      });

      // ── Update BackupJob stats ────────────────────────────────────────
      await BackupJob.findByIdAndUpdate(job._id, {
        "schedule.lastRun":   new Date(),
        "azure.lastBlobName": blobName,
        "azure.lastBlobUrl":  uploadResult.url,
        "azure.lastBlobSizeBytes": compSize,
        $inc: {
          "stats.totalRuns": 1, "stats.successfulRuns": 1,
          "stats.totalDataTransferred": compSize,
          "stats.totalBlobsCreated": 1,
        },
      });

      // ── Apply retention policy in Azure ───────────────────────────────
      await applyRetentionPolicy(job._id.toString(), job.retention.days, job.retention.maxVersions);

      // ── Track in App Insights ─────────────────────────────────────────
      trackEvent("BackupCompleted", { jobId: job._id.toString(), userId: user._id.toString(), blobName, sizeBytes: String(compSize), simulated: String(uploadResult.simulated) });
      trackMetric("BackupDurationMs",  duration);
      trackMetric("BackupSizeBytes",   compSize);
      trackMetric("UploadDurationMs",  uploadDurationMs);
      trackMetric("CompressionRatio",  origSize > 0 ? origSize / compSize : 1);

      console.log(`[Backup] ✓ ${job.name} → ${blobName} (${(compSize/1024/1024).toFixed(1)} MB, ${Math.floor(duration/1000)}s)`);

    } else {
      // ── Failure path ──────────────────────────────────────────────────
      const errors = [
        "Azure Blob Storage: connection timeout",
        "Source path not accessible — check permissions",
        "AzureStorageException: Container quota exceeded",
        "Checksum mismatch after upload — retrying not attempted",
        "Azure Key Vault: secret retrieval failed — encryption key unavailable",
        "Network interruption during blob upload",
      ];
      const errorMsg = errors[Math.floor(Math.random() * errors.length)];
      const duration = Date.now() - startMs;

      await BackupLog.findByIdAndUpdate(log._id, {
        status: "failed", endTime: new Date(), duration, errorMessage: errorMsg,
        $push: { logs: { level: "error", message: `Azure backup failed: ${errorMsg}` } },
      });
      await BackupJob.findByIdAndUpdate(job._id, {
        "schedule.lastRun": new Date(),
        $inc: { "stats.totalRuns": 1, "stats.failedRuns": 1 },
      });

      trackEvent("BackupFailed", { jobId: job._id.toString(), userId: user._id.toString(), error: errorMsg });
      console.error(`[Backup] ✗ ${job.name} — ${errorMsg}`);
    }
  } catch (err) {
    await BackupLog.findByIdAndUpdate(log._id, {
      status: "failed", endTime: new Date(), duration: 0, errorMessage: err.message,
      $push: { logs: { level: "error", message: `Unhandled backup error: ${err.message}` } },
    });
    console.error("[Backup] Unhandled error:", err.message);
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// 13. CRON SCHEDULER — auto-run active daily jobs
// ═══════════════════════════════════════════════════════════════════════════
const startScheduler = () => {
  // Run every hour and check for jobs whose nextRun has passed
  cron.schedule("0 * * * *", async () => {
    console.log("[Scheduler] Checking for due backup jobs…");
    try {
      const now  = new Date();
      const jobs = await BackupJob.find({ status: "active", "schedule.nextRun": { $lte: now } })
        .populate("user", "name email");

      for (const job of jobs) {
        const runId = uuidv4();
        const log = await BackupLog.create({
          job: job._id, user: job.user._id, runId,
          status: "running", triggeredBy: "schedule", startTime: new Date(),
          logs: [{ level: "info", message: "Scheduled backup triggered by cron" }],
        });
        executeAzureBackup(job, log, job.user).catch(e => console.error("[Scheduler] Backup error:", e.message));

        // Set next run based on frequency
        const nextRun = new Date();
        const freq = job.schedule.frequency;
        if (freq === "hourly")  nextRun.setHours(nextRun.getHours() + 1);
        else if (freq === "daily")  nextRun.setDate(nextRun.getDate() + 1);
        else if (freq === "weekly") nextRun.setDate(nextRun.getDate() + 7);
        else if (freq === "monthly") nextRun.setMonth(nextRun.getMonth() + 1);
        else nextRun.setDate(nextRun.getDate() + 1); // fallback

        await BackupJob.findByIdAndUpdate(job._id, { "schedule.nextRun": nextRun });
        console.log(`[Scheduler] Started: ${job.name} → next at ${nextRun.toISOString()}`);
      }
    } catch (err) {
      console.error("[Scheduler] Error:", err.message);
    }
  });
  console.log("[Scheduler] Hourly cron registered ✓");
};

// ═══════════════════════════════════════════════════════════════════════════
// 14. ERROR HANDLING
// ═══════════════════════════════════════════════════════════════════════════
app.use((req, res, next) => next(new AppError(`Route not found: ${req.originalUrl}`, 404)));
app.use((err, req, res, next) => {
  let { statusCode = 500, message = "Internal Server Error" } = err;
  if (err.name === "CastError")         { statusCode = 400; message = `Invalid ${err.path}: ${err.value}`; }
  if (err.code === 11000)               { statusCode = 400; message = `${Object.keys(err.keyValue)[0]} already exists.`; }
  if (err.name === "ValidationError")   { statusCode = 400; message = Object.values(err.errors).map(e => e.message).join(". "); }
  if (err.name === "JsonWebTokenError") { statusCode = 401; message = "Invalid token."; }
  if (err.name === "TokenExpiredError") { statusCode = 401; message = "Token expired."; }
  console.error(`[${statusCode}] ${req.method} ${req.originalUrl} — ${message}`);
  if (appInsights?.defaultClient) appInsights.defaultClient.trackException({ exception: err });
  res.status(statusCode).json({
    success: false,
    status:  String(statusCode).startsWith("4") ? "fail" : "error",
    message,
    ...(process.env.NODE_ENV === "development" && { stack: err.stack }),
  });
});

// ═══════════════════════════════════════════════════════════════════════════
// 15. BOOTSTRAP
// ═══════════════════════════════════════════════════════════════════════════
const start = async () => {
  try {
    // Resolve JWT_SECRET from Key Vault if configured
    await initKeyVault();
    const kvJwt = await getSecret("jwt-secret", "JWT_SECRET");
    if (kvJwt) JWT_SECRET = kvJwt;

    await connectDB();
    await initBlobStorage();
    startScheduler();

    const server = app.listen(PORT, () => {
      console.log(`\n🚀  Cloud Backup API (Azure Edition) on port ${PORT}`);
      console.log(`🔷  Azure Blob   : ${backupContainerClient ? `${AZURE_ACCOUNT}/${AZURE_CONTAINER}` : "SIMULATED"}`);
      console.log(`🔑  Key Vault    : ${kvClient  ? process.env.AZURE_KEYVAULT_URI : "disabled"}`);
      console.log(`📊  App Insights : ${appInsights ? "active" : "disabled"}`);
      console.log(`❤️   Health       : http://localhost:${PORT}/health\n`);
    });

    const graceful = async signal => {
      console.log(`\n[${signal}] Shutting down gracefully…`);
      server.close(async () => {
        await mongoose.connection.close();
        if (appInsights?.defaultClient) await appInsights.defaultClient.flush();
        console.log("[Shutdown] Done."); process.exit(0);
      });
    };
    process.on("SIGTERM", () => graceful("SIGTERM"));
    process.on("SIGINT",  () => graceful("SIGINT"));
    process.on("unhandledRejection", err => { console.error("Unhandled:", err.message); server.close(() => process.exit(1)); });
  } catch (err) {
    console.error("Boot failed:", err.message); process.exit(1);
  }
};

start();
module.exports = app;
