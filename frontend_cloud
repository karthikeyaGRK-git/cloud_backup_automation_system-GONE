<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CloudBackup Pro — Azure Edition</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://unpkg.com/recharts@2.8.0/umd/Recharts.js"></script>
<style>
:root{
  --bg:#060a12; --bg-s:#0c1120; --bg-c:#111927; --bg-ch:#172034;
  --bg-in:#080d18; --bg-az:#0a1428;
  --blue:#0078d4; --blue2:#106ebe; --blue-dim:rgba(0,120,212,.18);
  --blue-glow:rgba(0,120,212,.35);
  --az-blue:#0078d4; --az-light:#50e6ff; --az-purple:#5c2d91;
  --green:#10b981; --green-dim:rgba(16,185,129,.18);
  --amber:#f59e0b; --amber-dim:rgba(245,158,11,.18);
  --red:#ef4444;   --red-dim:rgba(239,68,68,.18);
  --t1:#eef4ff; --t2:#7fa5d8; --t3:#2e4a72;
  --border:#0f1e35; --border2:#172a45;
  --r-sm:7px; --r-md:12px; --r-lg:18px;
  --shadow:0 8px 36px rgba(0,0,0,.6);
  --font:'Inter',system-ui,sans-serif;
  --mono:'JetBrains Mono','Consolas',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body,#root{height:100%}
body{font-family:var(--font);background:var(--bg);color:var(--t1);overflow-x:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:99px}
::-webkit-scrollbar-thumb:hover{background:var(--az-blue)}

/* Layout */
.shell{display:flex;height:100vh;overflow:hidden}
.sidebar{width:236px;min-width:236px;background:var(--bg-s);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100}
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column}
.topbar{height:60px;background:var(--bg-s);border-bottom:1px solid var(--border);padding:0 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.page{padding:28px;flex:1}

/* Sidebar */
.sb-logo{padding:20px 16px 16px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}
.logo-ico{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#0078d4,#5c2d91);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.logo-txt{font-size:15px;font-weight:800;letter-spacing:-.3px;line-height:1.2}
.logo-txt span{color:var(--az-blue)}
.logo-sub{font-size:10px;color:var(--t3);font-weight:500;letter-spacing:.3px}
.sb-sec{padding:14px 14px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--t3)}
.nav{display:flex;align-items:center;gap:9px;padding:9px 10px;margin:2px 8px;border-radius:var(--r-sm);cursor:pointer;font-size:13px;font-weight:500;color:var(--t2);transition:all .13s;border:none;background:none;width:calc(100% - 16px);text-align:left}
.nav:hover{background:var(--bg-c);color:var(--t1)}
.nav.active{background:var(--blue-dim);color:var(--az-blue)}
.sb-foot{margin-top:auto;padding:14px;border-top:1px solid var(--border)}
.urow{display:flex;align-items:center;gap:9px;padding:9px;border-radius:var(--r-sm)}
.urow:hover{background:var(--bg-c)}
.av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#0078d4,#5c2d91);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.un{font-size:13px;font-weight:600}
.up{font-size:10.5px;color:var(--t3);text-transform:capitalize}

/* Cards */
.card{background:var(--bg-c);border:1px solid var(--border);border-radius:var(--r-lg)}
.card:hover{border-color:var(--border2)}
.az-card{background:linear-gradient(135deg,rgba(0,120,212,.12),rgba(92,45,145,.08));border:1px solid rgba(0,120,212,.25);border-radius:var(--r-lg)}

/* Grid */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}

/* Stat cards */
.stat{padding:20px 22px}
.s-lbl{font-size:11px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px}
.s-val{font-size:28px;font-weight:800;letter-spacing:-.5px;line-height:1}
.s-sub{font-size:12px;color:var(--t3);margin-top:6px}
.s-ico{width:38px;height:38px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 17px;border-radius:var(--r-sm);font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .13s;white-space:nowrap;font-family:var(--font)}
.btn:disabled{opacity:.45;cursor:not-allowed}
.btn-p{background:var(--az-blue);color:#fff}
.btn-p:hover:not(:disabled){background:var(--blue2);box-shadow:0 0 0 3px var(--blue-glow)}
.btn-g{background:var(--bg-c);color:var(--t2);border:1px solid var(--border)}
.btn-g:hover:not(:disabled){background:var(--bg-ch);color:var(--t1)}
.btn-d{background:var(--red-dim);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.btn-d:hover:not(:disabled){background:rgba(239,68,68,.3)}
.btn-ok{background:var(--green-dim);color:var(--green);border:1px solid rgba(16,185,129,.3)}
.btn-ok:hover:not(:disabled){background:rgba(16,185,129,.3)}
.btn-az{background:linear-gradient(135deg,#0078d4,#5c2d91);color:#fff}
.btn-az:hover:not(:disabled){box-shadow:0 0 0 3px rgba(0,120,212,.4)}
.btn-sm{padding:5px 11px;font-size:12px}
.btn-ic{padding:7px}
.wf{width:100%;justify-content:center}

/* Inputs */
.fg{margin-bottom:16px}
.lbl{display:block;font-size:12px;font-weight:600;color:var(--t2);margin-bottom:5px}
.inp{width:100%;padding:9px 13px;background:var(--bg-in);border:1px solid var(--border);border-radius:var(--r-sm);color:var(--t1);font-size:13px;outline:none;transition:border-color .13s;font-family:var(--font)}
.inp:focus{border-color:var(--az-blue);box-shadow:0 0 0 3px var(--blue-dim)}
.inp::placeholder{color:var(--t3)}
.inp.err{border-color:var(--red)}
select.inp{appearance:none;cursor:pointer}
textarea.inp{resize:vertical}
.err-t{font-size:11px;color:var(--red);margin-top:3px}

/* Badges */
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:99px;font-size:11px;font-weight:600}
.b-green{background:var(--green-dim);color:var(--green)}
.b-blue{background:var(--blue-dim);color:var(--az-blue)}
.b-amber{background:var(--amber-dim);color:var(--amber)}
.b-red{background:var(--red-dim);color:var(--red)}
.b-gray{background:rgba(100,116,139,.15);color:#64748b}
.b-azure{background:linear-gradient(135deg,rgba(0,120,212,.2),rgba(92,45,145,.2));color:var(--az-light);border:1px solid rgba(80,230,255,.2)}

/* Azure service status pills */
.az-pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:99px;font-size:11px;font-weight:600;background:var(--blue-dim);color:var(--az-light);border:1px solid rgba(80,230,255,.2)}
.az-pill-off{background:rgba(100,116,139,.1);color:var(--t3);border:1px solid var(--border)}

/* Table */
.tbl-wrap{overflow-x:auto;border-radius:var(--r-lg)}
table{width:100%;border-collapse:collapse}
thead{background:var(--bg-in)}
th{padding:11px 16px;text-align:left;font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
td{padding:13px 16px;font-size:13px;color:var(--t2);border-top:1px solid var(--border)}
tr:hover td{background:var(--bg-ch)}
.td-p{color:var(--t1);font-weight:600}

/* Progress */
.pbar{width:100%;height:5px;background:var(--bg-in);border-radius:99px;overflow:hidden}
.pfill{height:100%;border-radius:99px;transition:width .3s}

/* Modal */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;animation:fadein .15s}
.modal{background:var(--bg-s);border:1px solid var(--border2);border-radius:var(--r-lg);width:100%;max-width:580px;max-height:90vh;overflow-y:auto;animation:slideup .2s}
.m-hdr{padding:22px 26px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.m-ttl{font-size:17px;font-weight:700}
.m-bdy{padding:22px 26px}
.m-ftr{padding:14px 26px 22px;display:flex;gap:10px;justify-content:flex-end}

/* Auth */
.auth-shell{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:20px;position:relative;overflow:hidden}
.auth-shell::before{content:'';position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(0,120,212,.08),transparent 70%);top:-200px;left:-200px;pointer-events:none}
.auth-shell::after{content:'';position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(92,45,145,.07),transparent 70%);bottom:-100px;right:-100px;pointer-events:none}
.auth-card{background:var(--bg-s);border:1px solid var(--border2);border-radius:var(--r-lg);padding:38px;width:100%;max-width:420px;box-shadow:var(--shadow);position:relative;z-index:1}
.a-ttl{font-size:24px;font-weight:800;text-align:center;margin-bottom:6px}
.a-sub{font-size:13px;color:var(--t3);text-align:center;margin-bottom:28px}
.a-lnk{color:var(--az-blue);font-size:13px;font-weight:600;text-decoration:none;cursor:pointer}
.a-lnk:hover{text-decoration:underline}

/* Toast */
.twrap{position:fixed;top:18px;right:18px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--bg-c);border:1px solid var(--border2);border-radius:var(--r-sm);padding:12px 16px;font-size:13px;display:flex;align-items:center;gap:10px;box-shadow:var(--shadow);animation:slidein .2s;min-width:270px;max-width:370px}
.t-ok{border-left:3px solid var(--green)}
.t-er{border-left:3px solid var(--red)}
.t-in{border-left:3px solid var(--az-blue)}

/* Azure banner */
.az-banner{background:linear-gradient(135deg,rgba(0,120,212,.15),rgba(92,45,145,.1));border:1px solid rgba(0,120,212,.3);border-radius:var(--r-md);padding:16px 20px;display:flex;align-items:center;gap:14px;margin-bottom:24px}
.az-banner-ico{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#0078d4,#5c2d91);display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* Azure services grid */
.az-service{background:var(--bg-az);border:1px solid rgba(0,120,212,.2);border-radius:var(--r-md);padding:16px;display:flex;flex-direction:column;gap:10px}
.az-svc-name{font-size:13px;font-weight:700;color:var(--t1)}
.az-svc-sub{font-size:11.5px;color:var(--t3);line-height:1.5}
.az-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.az-dot-on{background:var(--green)}
.az-dot-off{background:var(--t3)}
.az-dot-sim{background:var(--amber)}

/* Misc */
.chip{display:inline-flex;align-items:center;padding:2px 9px;border-radius:99px;font-size:11px;background:var(--bg-in);color:var(--t3);border:1px solid var(--border)}
.chip-az{background:rgba(0,120,212,.12);color:var(--az-blue);border-color:rgba(0,120,212,.3)}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--green);position:relative;flex-shrink:0}
.pulse::before{content:'';position:absolute;inset:-3px;border-radius:50%;background:var(--green);opacity:.3;animation:pulseA 1.6s infinite}
.spin{width:18px;height:18px;border:2px solid var(--border2);border-top-color:var(--az-blue);border-radius:50%;animation:spin .65s linear infinite}
.loader{display:flex;align-items:center;justify-content:center;height:220px}
.empty{text-align:center;padding:52px 20px}
.e-ico{font-size:44px;margin-bottom:14px;opacity:.45}
.e-ttl{font-size:17px;font-weight:700;margin-bottom:7px}
.e-sub{font-size:13px;color:var(--t3);margin-bottom:22px}
.divider{height:1px;background:var(--border);margin:16px 0}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px}
.sttl{font-size:20px;font-weight:800}
.ssub{font-size:12px;color:var(--t3);margin-top:2px}
.cht{font-size:14px;font-weight:700;margin-bottom:3px}
.chs{font-size:11.5px;color:var(--t3);margin-bottom:16px}
.mono{font-family:var(--mono)}

/* Flex utils */
.fx{display:flex}.fxc{flex-direction:column}
.aic{align-items:center}.afs{align-items:flex-start}
.jb{justify-content:space-between}.je{justify-content:flex-end}
.g2u{gap:8px}.g3u{gap:12px}.g4u{gap:16px}
.mt2{margin-top:8px}.mt4{margin-top:16px}.mt6{margin-top:24px}
.mb4{margin-bottom:16px}.mb6{margin-bottom:24px}
.p4{padding:16px}.p6{padding:24px}
.trunc{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cg{color:var(--green)}.cr{color:var(--red)}.cb{color:var(--az-blue)}.ca{color:var(--amber)}.ct2{color:var(--t2)}.ct3{color:var(--t3)}
.fw6{font-weight:600}.fw7{font-weight:700}.fw8{font-weight:800}
.fs11{font-size:11px}.fs12{font-size:12px}.fs13{font-size:13px}

@keyframes fadein{from{opacity:0}to{opacity:1}}
@keyframes slideup{from{transform:translateY(16px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes slidein{from{transform:translateX(110px);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulseA{0%,100%{transform:scale(1);opacity:.3}50%{transform:scale(2);opacity:0}}

@media(max-width:900px){.sidebar{display:none}.g4{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.g4,.g3,.g2{grid-template-columns:1fr}.page{padding:14px}}
</style>
</head>
<body>
<div id="root"></div>
<script>
  // ── SET YOUR RENDER BACKEND URL HERE ─────────────────────────────────────
  window.BACKEND_URL = "https://your-render-backend.onrender.com";
  // For local dev: window.BACKEND_URL = "http://localhost:5000";
</script>
<script type="text/babel">
"use strict";
const { useState, useEffect, useCallback, createContext, useContext } = React;
const API_ROOT = (window.BACKEND_URL || "http://localhost:5000") + "/api";

/* ── Toast ─────────────────────────────────────────────────────────────── */
const ToastCtx = createContext(null);
const ToastProvider = ({ children }) => {
  const [list, setList] = useState([]);
  const push = useCallback((msg, type) => {
    const id = Date.now() + Math.random();
    setList(p => [...p, { id, msg, type }]);
    setTimeout(() => setList(p => p.filter(t => t.id !== id)), 4000);
  }, []);
  return (
    <ToastCtx.Provider value={{ success:m=>push(m,"ok"), error:m=>push(m,"er"), info:m=>push(m,"in") }}>
      {children}
      <div className="twrap">
        {list.map(t=>(
          <div key={t.id} className={`toast t-${t.type}`}>
            <span style={{fontWeight:800}}>{t.type==="ok"?"✓":t.type==="er"?"✕":"·"}</span>
            <span>{t.msg}</span>
          </div>
        ))}
      </div>
    </ToastCtx.Provider>
  );
};
const useToast = () => useContext(ToastCtx);

/* ── API client ─────────────────────────────────────────────────────────── */
const req = async (path, opts = {}) => {
  const token = localStorage.getItem("token");
  const res = await fetch(API_ROOT + path, {
    headers: { "Content-Type":"application/json", ...(token ? { Authorization:`Bearer ${token}` } : {}) },
    credentials: "include", ...opts,
    body: opts.body ? JSON.stringify(opts.body) : undefined,
  });
  const data = await res.json();
  if (!res.ok) throw new Error(data.message || data.errors?.[0]?.msg || "Request failed");
  return data;
};
const API = {
  auth:  { register:d=>req("/auth/register",{method:"POST",body:d}), login:d=>req("/auth/login",{method:"POST",body:d}), logout:()=>req("/auth/logout",{method:"POST"}), me:()=>req("/auth/me"), updateProfile:d=>req("/auth/update-profile",{method:"PATCH",body:d}) },
  jobs:  { list:(p={})=>req("/jobs?"+new URLSearchParams(p)), get:id=>req(`/jobs/${id}`), create:d=>req("/jobs",{method:"POST",body:d}), update:(id,d)=>req(`/jobs/${id}`,{method:"PATCH",body:d}), del:id=>req(`/jobs/${id}`,{method:"DELETE"}), run:id=>req(`/jobs/${id}/run`,{method:"POST"}), logs:(id,p={})=>req(`/jobs/${id}/logs?`+new URLSearchParams(p)), blobs:id=>req(`/jobs/${id}/blobs`), retention:id=>req(`/jobs/${id}/apply-retention`,{method:"POST"}) },
  dash:  { stats:()=>req("/dashboard/stats"), activity:(p={})=>req("/dashboard/activity?"+new URLSearchParams(p)) },
  azure: { info:()=>req("/azure/storage-info") },
};

/* ── Auth context ───────────────────────────────────────────────────────── */
const AuthCtx = createContext(null);
const AuthProvider = ({ children }) => {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const toast = useToast();
  useEffect(() => {
    if (!localStorage.getItem("token")) { setLoading(false); return; }
    API.auth.me().then(r=>setUser(r.data.user)).catch(()=>localStorage.removeItem("token")).finally(()=>setLoading(false));
  }, []);
  const login    = async d => { const r=await API.auth.login(d); localStorage.setItem("token",r.token); setUser(r.data.user); toast.success(`Welcome back, ${r.data.user.name}!`); };
  const register = async d => { const r=await API.auth.register(d); localStorage.setItem("token",r.token); setUser(r.data.user); toast.success(`Welcome, ${r.data.user.name}!`); };
  const logout   = async () => { try{await API.auth.logout();}catch{} localStorage.removeItem("token"); setUser(null); toast.info("Signed out."); };
  return <AuthCtx.Provider value={{user,loading,login,register,logout,setUser}}>{children}</AuthCtx.Provider>;
};
const useAuth = () => useContext(AuthCtx);

/* ── Helpers ────────────────────────────────────────────────────────────── */
const fmtB   = b => { if(!b)return"0 B"; const k=1024,u=["B","KB","MB","GB","TB"],i=Math.floor(Math.log(b)/Math.log(k)); return`${(b/Math.pow(k,i)).toFixed(1)} ${u[i]}`; };
const fmtAgo = d => { if(!d)return"Never"; const s=Math.floor((Date.now()-new Date(d))/1000); if(s<60)return"Just now"; if(s<3600)return`${Math.floor(s/60)}m ago`; if(s<86400)return`${Math.floor(s/3600)}h ago`; return new Date(d).toLocaleDateString(); };
const fmtD   = d => d?new Date(d).toLocaleString("en-US",{month:"short",day:"numeric",year:"numeric",hour:"2-digit",minute:"2-digit"}):"N/A";
const fmtMs  = ms => { if(!ms)return"N/A"; const s=Math.floor(ms/1000); return s<60?`${s}s`:`${Math.floor(s/60)}m ${s%60}s`; };
const dotClr = s => ({active:"#10b981",completed:"#10b981",running:"#0078d4",paused:"#f59e0b",failed:"#ef4444",disabled:"#475569"}[s]||"#475569");

const Badge = ({s}) => {
  const cls = {active:"b-green",completed:"b-green",running:"b-blue",pending:"b-blue",paused:"b-amber",failed:"b-red",error:"b-red",disabled:"b-gray",cancelled:"b-gray"};
  return <span className={`badge ${cls[s]||"b-gray"}`}>{s}</span>;
};

/* ── Azure Logo SVG ─────────────────────────────────────────────────────── */
const AzLogo = ({ sz=20 }) => (
  <svg width={sz} height={sz} viewBox="0 0 96 96" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="azg1" x1="-.5%" x2="100%" y1="50%" y2="50%"><stop offset="0" stopColor="#114A8B"/><stop offset="1" stopColor="#0669BC"/></linearGradient>
      <linearGradient id="azg2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0" stopColor="#0078D4"/><stop offset="1" stopColor="#1490DF"/></linearGradient>
    </defs>
    <path d="M33.34 6.54h28.67L37.66 90.48a4.56 4.56 0 01-4.33 3.15H9.81a4.56 4.56 0 01-4.29-6.07L29.01 9.7a4.56 4.56 0 014.33-3.16z" fill="url(#azg1)"/>
