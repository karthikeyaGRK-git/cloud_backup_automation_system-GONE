const CreateJob = ({open,onClose,onOk}) => {
  const toast=useToast(); const [step,setStep]=useState(1); const [busy,setBusy]=useState(false); const [tagIn,setTagIn]=useState("");
  const init={name:"",description:"",source:{type:"local",path:""},destination:{type:"azure_blob",path:""},schedule:{frequency:"daily",cronExpression:"0 2 * * *",timezone:"UTC"},retention:{days:30,maxVersions:10},compression:{enabled:true,algorithm:"gzip"},encryption:{enabled:true,keyVaultSecretName:""},tags:[],notifyOnFailure:true,notifyOnSuccess:false};
  const [f,setF]=useState(init);
  const set=(path,val)=>setF(prev=>{const n={...prev};const keys=path.split(".");let c=n;for(let i=0;i<keys.length-1;i++)c=c[keys[i]]={...c[keys[i]]};c[keys[keys.length-1]]=val;return n;});
  const FREQS=[{v:"manual",l:"Manual only",c:""},{v:"hourly",l:"Every hour",c:"0 * * * *"},{v:"daily",l:"Daily at 2:00 AM",c:"0 2 * * *"},{v:"weekly",l:"Weekly (Sunday 2AM)",c:"0 2 * * 0"},{v:"monthly",l:"Monthly (1st, 2AM)",c:"0 2 1 * *"}];
  const DEST_TYPES=[{v:"azure_blob",l:"Azure Blob (Hot)"},{v:"azure_cool",l:"Azure Blob (Cool)"},{v:"azure_archive",l:"Azure Blob (Archive)"},{v:"azure_files",l:"Azure Files"},{v:"s3",l:"AWS S3"},{v:"gcs",l:"Google Cloud Storage"},{v:"local",l:"Local Storage"}];
  const SRC_TYPES=[{v:"local",l:"Local filesystem"},{v:"azure_blob",l:"Azure Blob Storage"},{v:"azure_cosmos",l:"Azure Cosmos DB"},{v:"azure_sql",l:"Azure SQL Database"},{v:"azure_files",l:"Azure Files"},{v:"s3",l:"AWS S3"},{v:"gcs",l:"GCS"},{v:"database",l:"Generic database"}];
  const submit=async()=>{
    if(!f.name.trim())return toast.error("Job name required");
    if(!f.source.path.trim())return toast.error("Source path required");
    if(!f.destination.path.trim())return toast.error("Destination path required");
    setBusy(true);
    try{await API.jobs.create(f);toast.success("Azure backup job created!");onOk();onClose();setStep(1);setF(init);}
    catch(err){toast.error(err.message);}
    finally{setBusy(false);}
  };
  const addTag=()=>{const t=tagIn.trim();if(t&&!f.tags.includes(t))set("tags",[...f.tags,t]);setTagIn("");};
  const footer=(
    <>{step>1&&<button className="btn btn-g" onClick={()=>setStep(s=>s-1)}>← Back</button>}
    <button className="btn btn-g" onClick={onClose}>Cancel</button>
    {step<3?<button className="btn btn-p" onClick={()=>setStep(s=>s+1)}>Next →</button>
            :<button className="btn btn-az" onClick={submit} disabled={busy}>{busy?<Spin sz={13}/>:null}<AzLogo sz={14}/>Create Azure Job</button>}</>
  );
  return(
    <Modal open={open} onClose={onClose} title={`New Azure Backup Job — Step ${step} of 3`} footer={footer}>
      {step===1&&<>
        <div className="fg"><label className="lbl">Job name *</label><input className="inp" placeholder="e.g. Production DB — Azure Daily Backup" value={f.name} onChange={e=>set("name",e.target.value)}/></div>
        <div className="fg"><label className="lbl">Description</label><textarea className="inp" rows={2} placeholder="Optional…" value={f.description} onChange={e=>set("description",e.target.value)}/></div>
        <div className="g2">
          <div className="fg" style={{marginBottom:0}}><label className="lbl">Source type *</label>
