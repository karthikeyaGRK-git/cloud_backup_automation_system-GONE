          </div>
          <div className="az-card p6">
            <div className="fx aic g2u mb4"><AzLogo sz={18}/><div className="fw7 fs13">Azure Blob Storage Usage</div></div>
            <div className="fx jb fs12 ct3 mb4"><span>{fmtB(used)} used of {fmtB(limit)}</span><span>{pct}%</span></div>
            <div className="pbar" style={{height:8}}><div className="pfill" style={{width:`${pct}%`,background:pclr}}/></div>
            <div className="fx jb mt4 fs12">
              <span className="ct3">Blobs stored: <span className="fw6 cb">{user?.azure?.blobCount||0}</span></span>
              <span className="ct3">Last synced: <span className="fw6">{fmtAgo(user?.azure?.lastSyncedAt)}</span></span>
            </div>
          </div>
        </div>
        <div>
          <div className="card p6 mb4">
            <div className="fw8 mb4" style={{fontSize:16}}>Account Information</div>
            {[["Email",user?.email],["Role",user?.role],["Plan",user?.plan],["Last login",fmtD(user?.lastLogin)],["Member since",fmtD(user?.createdAt)]].map(([k,v])=>(
              <div key={k} className="fx jb" style={{padding:"10px 0",borderBottom:"1px solid var(--border)"}}>
                <span className="fs13 ct3">{k}</span><span className="fs13 fw6">{v||"—"}</span>
              </div>
            ))}
          </div>
          <div className="az-card p6">
            <div className="fx aic g2u mb4"><AzLogo sz={18}/><div className="fw7 fs13">Azure Security</div></div>
            {[
              {l:"Encryption",v:"AES-256-GCM at rest",ok:true},
              {l:"Key management",v:"Azure Key Vault (when configured)",ok:true},
              {l:"Token auth",v:"JWT — 7-day expiry",ok:true},
              {l:"Password hashing",v:"bcrypt — cost factor 12",ok:true},
              {l:"Download links",v:"Time-limited SAS URLs",ok:true},
              {l:"Transport",v:"TLS 1.2+ enforced",ok:true},
            ].map(({l,v,ok})=>(
              <div key={l} className="fx aic g2u" style={{padding:"8px 0",borderBottom:"1px solid rgba(0,120,212,.1)"}}>
                <span style={{fontSize:12,color:ok?"var(--green)":"var(--amber)",fontWeight:700}}>✓</span>
                <span className="fs12 ct3" style={{flex:1}}>{l}</span>
                <span className="fs12 fw6">{v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};

/* ── App shell ───────────────────────────────────────────────────────────── */
const Shell = () => {
  const [pg,setPg]=useState("dashboard");
  const pages={dashboard:<DashboardPage/>,jobs:<JobsPage/>,logs:<LogsPage/>,azure:<AzurePage/>,settings:<SettingsPage/>};
  const titles={dashboard:"Dashboard",jobs:"Backup Jobs",logs:"Activity Logs",azure:"Azure Services",settings:"Settings"};
  return(
    <div className="shell">
      <Sidebar pg={pg} setPg={setPg}/>
      <div className="main">
        <div className="topbar">
          <div className="fx aic g2u"><AzLogo sz={16}/><span className="fw7" style={{fontSize:15}}>{titles[pg]}</span></div>
          <div className="fx aic g2u">
            <span className="chip chip-az fs11">🔷 Azure Edition</span>
            <button className="btn btn-g btn-sm btn-ic" onClick={()=>window.location.reload()} title="Refresh"><Ico n="refresh" sz={14}/></button>
            <button className="btn btn-g btn-sm btn-ic" title="Notifications"><Ico n="bell" sz={14}/></button>
          </div>
        </div>
        {pages[pg]}
      </div>
    </div>
  );
};

const App = () => {
  const [view,setView]=useState("login");
  return(
    <ToastProvider><AuthProvider><Gate view={view} setView={setView}/></AuthProvider></ToastProvider>
  );
};

const Gate = ({view,setView}) => {
  const {user,loading}=useAuth();
  if(loading)return(
    <div style={{height:"100vh",display:"flex",alignItems:"center",justifyContent:"center",flexDirection:"column",gap:16}}>
      <div style={{width:54,height:54,borderRadius:14,background:"linear-gradient(135deg,#0078d4,#5c2d91)",display:"flex",alignItems:"center",justifyContent:"center"}}>
        <AzLogo sz={32}/>
      </div>
      <Spin sz={22}/>
      <div className="fs12 ct3">Connecting to Azure services…</div>
    </div>
  );
  if(!user)return view==="login"?<Login flip={()=>setView("register")}/>:<Register flip={()=>setView("login")}/>;
  return <Shell/>;
};

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
